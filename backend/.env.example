# PriorAuth AI backend environment configuration

# Required for live AI mode. Leave blank to run entirely in fallback mode.
# Use a provider key that matches the API_BASE_URL below.
API_KEY=your_provider_api_key_here

# Optional: override the provider base URL if needed.
# Current supported live provider path:
API_BASE_URL=https://api.mistral.ai/v1

# Model selection
# Use one model across all three agents. Mistral Small is the low-cost default pick.
MODEL=mistral-small-latest

# Optional tuning
RESPONSE_CACHE_TTL=3600
MANUAL_BENCHMARK_SECONDS=2700
PIPELINE_TIMEOUT=480
COST_PER_1M_TOKENS=0.10
AVG_TOKENS_PER_AGENT=1500
